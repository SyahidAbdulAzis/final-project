PORT=8000
DATABASE_URL=postgresql://user:password@localhost:5432/property_renting
JWT_SECRET=replace_me

# Email — Fitur 1 (Mailtrap)
# Lokal: pakai SMTP (email masuk ke dashboard Mailtrap)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
# Production: pakai Mailtrap API (HTTP, bypass port block di Render)
# Dapatkan API key di: https://mailtrap.io/api-keys
MAILTRAP_API_KEY=your_mailtrap_api_key
MAIL_FROM=noreply@stayease.com

# Email — Fitur 2 (Resend, milik partner)
# Daftar: https://resend.com | Dapatkan API key di dashboard
RESEND_API_KEY=re_your_api_key_here

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL
FRONTEND_URL=http://localhost:5173
